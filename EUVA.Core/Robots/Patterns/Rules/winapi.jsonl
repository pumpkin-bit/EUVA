{"id":"winapi_strip_dll","category":"winapi","description":"Remove DLL:: prefix from WinAPI calls","pattern":"(?:kernel32|user32|advapi32|gdi32|ntdll|shell32|ole32|comctl32|ws2_32|wininet|crypt32|shlwapi)::(\\w+)\\(","replacement":"$1(","mode":"regex","priority":100,"requires_context":false}
{"id":"winapi_sem_flags","category":"winapi","description":"SEM_FAILCRITICALERRORS | SEM_NOOPENFILEERRORBOX","pattern":"SetErrorMode\\(\\s*(?:0x8001|32769)\\s*\\)","replacement":"SetErrorMode(SEM_FAILCRITICALERRORS | SEM_NOOPENFILEERRORBOX)","mode":"regex","priority":90,"requires_context":false}
{"id":"winapi_ewx_reboot","category":"winapi","description":"EWX_REBOOT constant","pattern":"ExitWindowsEx\\(\\s*(?:0x2|2)\\s*,","replacement":"ExitWindowsEx(EWX_REBOOT,","mode":"regex","priority":90,"requires_context":false}
{"id":"winapi_ewx_poweroff","category":"winapi","description":"EWX_POWEROFF constant","pattern":"ExitWindowsEx\\(\\s*(?:0x8|8)\\s*,","replacement":"ExitWindowsEx(EWX_POWEROFF,","mode":"regex","priority":90,"requires_context":false}
{"id":"winapi_mb_ok","category":"winapi","description":"MB_OK constant","pattern":"MessageBoxW?A?\\(([^,]+),\\s*([^,]+),\\s*([^,]+),\\s*(?:0x0|0)\\s*\\)","replacement":"MessageBoxA($1, $2, $3, MB_OK)","mode":"regex","priority":88,"requires_context":false}
{"id":"winapi_sw_show","category":"winapi","description":"SW_SHOW constant","pattern":"ShowWindow\\(([^,]+),\\s*(?:0x5|5)\\s*\\)","replacement":"ShowWindow($1, SW_SHOW)","mode":"regex","priority":88,"requires_context":false}
{"id":"winapi_sw_hide","category":"winapi","description":"SW_HIDE constant","pattern":"ShowWindow\\(([^,]+),\\s*(?:0x0|0)\\s*\\)","replacement":"ShowWindow($1, SW_HIDE)","mode":"regex","priority":88,"requires_context":false}
{"id":"winapi_generic_read","category":"winapi","description":"GENERIC_READ constant","pattern":"CreateFile[WA]?\\(([^,]+),\\s*(?:0x80000000|2147483648)\\s*,","replacement":"CreateFileA($1, GENERIC_READ,","mode":"regex","priority":87,"requires_context":false}
{"id":"winapi_generic_write","category":"winapi","description":"GENERIC_WRITE constant","pattern":"CreateFile[WA]?\\(([^,]+),\\s*(?:0x40000000|1073741824)\\s*,","replacement":"CreateFileA($1, GENERIC_WRITE,","mode":"regex","priority":87,"requires_context":false}
{"id":"winapi_invalid_handle","category":"winapi","description":"INVALID_HANDLE_VALUE constant","pattern":"==\\s*(?:0xFFFFFFFFFFFFFFFF|-1)(?=\\s*[);])","replacement":"== INVALID_HANDLE_VALUE","mode":"regex","priority":85,"requires_context":false}
{"id":"winapi_null_ptr","category":"winapi","description":"NULL pointer constant","pattern":"(?<=[(,=])\\s*(?:0x0|0)(?=\\s*[),;])","replacement":" nullptr","mode":"regex","priority":60,"requires_context":false,"guard":"(?:Handle|Alloc|Window|Create|Open|Find|Load)"}
{"id":"winapi_lstrlenA","category":"winapi","description":"lstrlenA -> strlen","pattern":"\\blstrlenA\\(","replacement":"strlen(","mode":"regex","priority":92,"requires_context":false}
{"id":"winapi_lstrlenW","category":"winapi","description":"lstrlenW -> wcslen","pattern":"\\blstrlenW\\(","replacement":"wcslen(","mode":"regex","priority":92,"requires_context":false}
{"id":"winapi_lstrcpyA","category":"winapi","description":"lstrcpyA -> strcpy","pattern":"\\blstrcpyA\\(","replacement":"strcpy(","mode":"regex","priority":92,"requires_context":false}
{"id":"winapi_lstrcpyW","category":"winapi","description":"lstrcpyW -> wcscpy","pattern":"\\blstrcpyW\\(","replacement":"wcscpy(","mode":"regex","priority":92,"requires_context":false}
{"id":"winapi_lstrcmpA","category":"winapi","description":"lstrcmpA -> strcmp","pattern":"\\blstrcmpA\\(","replacement":"strcmp(","mode":"regex","priority":92,"requires_context":false}
{"id":"winapi_lstrcmpiW","category":"winapi","description":"lstrcmpiW -> _wcsicmp","pattern":"\\blstrcmpiW\\(","replacement":"_wcsicmp(","mode":"regex","priority":92,"requires_context":false}
{"id":"winapi_lstrcatA","category":"winapi","description":"lstrcatA -> strcat","pattern":"\\blstrcatA\\(","replacement":"strcat(","mode":"regex","priority":92,"requires_context":false}
