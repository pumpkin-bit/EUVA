{"id":"compiler_null_check","category":"compiler","description":"if (x == 0) -> if (!x)","pattern":"if\\s*\\(\\s*(\\w+)\\s*==\\s*0\\s*\\)","replacement":"if (!$1)","mode":"regex","priority":50,"requires_context":false}
{"id":"compiler_not_null","category":"compiler","description":"if (x != 0) -> if (x)","pattern":"if\\s*\\(\\s*(\\w+)\\s*!=\\s*0\\s*\\)","replacement":"if ($1)","mode":"regex","priority":50,"requires_context":false}
{"id":"compiler_bool_ternary","category":"compiler","description":"x = (y != 0) ? 1 : 0 -> x = static_cast<bool>(y)","pattern":"(\\w+)\\s*=\\s*\\(\\s*(\\w+)\\s*!=\\s*0\\s*\\)\\s*\\?\\s*1\\s*:\\s*0","replacement":"$1 = static_cast<bool>($2)","mode":"regex","priority":45,"requires_context":false}
{"id":"compiler_deref_offset","category":"compiler","description":"*(ptr + offset) -> ptr[offset]","pattern":"\\*\\(\\s*(\\w+)\\s*\\+\\s*(\\w+)\\s*\\)","replacement":"$1[$2]","mode":"regex","priority":60,"requires_context":false}
{"id":"compiler_deref_const_offset","category":"compiler","description":"*(ptr + 0xN) -> ptr[0xN]","pattern":"\\*\\(\\s*(\\w+)\\s*\\+\\s*(0x[0-9A-Fa-f]+)\\s*\\)","replacement":"$1[$2]","mode":"regex","priority":61,"requires_context":false}
{"id":"compiler_self_xor","category":"compiler","description":"x ^= x -> x = 0 (compiler zero idiom)","pattern":"(\\w+)\\s*\\^=\\s*\\1\\s*;","replacement":"$1 = 0; // compiler zero idiom","mode":"regex","priority":55,"requires_context":false}
{"id":"compiler_lea_multiply","category":"compiler","description":"x + x -> x * 2","pattern":"(\\w+)\\s*\\+\\s*\\1(?=\\s*[;,)])","replacement":"$1 * 2","mode":"regex","priority":40,"requires_context":false}
{"id":"compiler_sub_neg","category":"compiler","description":"0 - x -> -x","pattern":"(?<=\\s)0\\s*-\\s*(\\w+)","replacement":"-$1","mode":"regex","priority":40,"requires_context":false}
{"id":"compiler_double_neg","category":"compiler","description":"!!x idiom to bool","pattern":"!\\s*!\\s*(\\w+)","replacement":"static_cast<bool>($1)","mode":"regex","priority":45,"requires_context":false}
{"id":"compiler_mul1","category":"compiler","description":"x * 1 -> x","pattern":"(\\w+)\\s*\\*\\s*1(?=\\s*[;,)+\\-])","replacement":"$1","mode":"regex","priority":55,"requires_context":false}
{"id":"compiler_add0","category":"compiler","description":"x + 0 -> x","pattern":"(\\w+)\\s*\\+\\s*0(?=\\s*[;,)])","replacement":"$1","mode":"regex","priority":55,"requires_context":false}
{"id":"compiler_or0","category":"compiler","description":"x | 0 -> x","pattern":"(\\w+)\\s*\\|\\s*0(?=\\s*[;,)])","replacement":"$1","mode":"regex","priority":55,"requires_context":false}
{"id":"compiler_and_ff","category":"compiler","description":"x & 0xFFFFFFFF -> (uint32_t)x","pattern":"(\\w+)\\s*&\\s*0xFFFFFFFF(?=\\s*[;,)])","replacement":"(uint32_t)$1","mode":"regex","priority":52,"requires_context":false}
{"id":"compiler_scale_2","category":"compiler","description":"x + x * 2 simplify to x * 3","pattern":"(\\w+)\\s*\\+\\s*\\1\\s*\\*\\s*2","replacement":"$1 * 3","mode":"regex","priority":40,"requires_context":false}
{"id":"compiler_increment_1","category":"compiler","description":"x += 1 -> x++","pattern":"(\\w+)\\s*\\+=\\s*1\\s*;","replacement":"$1++;","mode":"regex","priority":48,"requires_context":false}
{"id":"compiler_decrement_1","category":"compiler","description":"x -= 1 -> x--","pattern":"(\\w+)\\s*-=\\s*1\\s*;","replacement":"$1--;","mode":"regex","priority":48,"requires_context":false}
{"id":"compiler_rax_discard","category":"compiler","description":"rax = VoidFunc() strip rax assignment","pattern":"^(\\s*)rax\\s*=\\s*(SetErrorMode|ExitProcess|OleUninitialize|CloseHandle|SetCurrentDirectoryW?|SetEnvironmentVariableW?|OleInitialize|Sleep|FreeLibrary)\\(","replacement":"$1$2(","mode":"regex","priority":70,"requires_context":false}
{"id":"compiler_ptr_index_2","category":"compiler","description":"(ptr + 1 * 2) -> ptr + sizeof(WCHAR)","pattern":"\\(\\s*(\\w+)\\s*\\+\\s*1\\s*\\*\\s*2\\s*\\)","replacement":"($1 + sizeof(WCHAR))","mode":"regex","priority":58,"requires_context":false}
{"id":"compiler_sub_1_1","category":"compiler","description":"(x - 1 - 1) -> (x - 2)","pattern":"\\(\\s*(\\w+)\\s*-\\s*1\\s*-\\s*1\\s*\\)","replacement":"($1 - 2)","mode":"regex","priority":55,"requires_context":false}
