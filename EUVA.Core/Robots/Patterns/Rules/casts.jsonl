{"id":"cast_func_ptr","category":"cast","description":"C function pointer cast to reinterpret_cast","pattern":"\\(\\(([^()]+?)\\s*\\(\\*\\)\\(([^()]*)\\)\\)(\\w+)\\)","replacement":"reinterpret_cast<$1(*)($2)>($3)","mode":"regex","priority":95,"requires_context":false}
{"id":"cast_void_star","category":"cast","description":"(void*)expr to static_cast<void*>","pattern":"\\(void\\s*\\*\\)\\s*([a-zA-Z_]\\w*(?:\\([^)]*\\))?)","replacement":"static_cast<void*>($1)","mode":"regex","priority":80,"requires_context":false}
{"id":"cast_int_ptr","category":"cast","description":"(int*)expr to reinterpret_cast<int*>","pattern":"\\(int\\s*\\*\\)\\s*([a-zA-Z_]\\w*(?:\\([^)]*\\))?)","replacement":"reinterpret_cast<int*>($1)","mode":"regex","priority":80,"requires_context":false}
{"id":"cast_char_ptr","category":"cast","description":"(char*)expr to reinterpret_cast<char*>","pattern":"\\(char\\s*\\*\\)\\s*([a-zA-Z_]\\w*(?:\\([^)]*\\))?)","replacement":"reinterpret_cast<char*>($1)","mode":"regex","priority":80,"requires_context":false}
{"id":"cast_unsigned_int","category":"cast","description":"(unsigned int)expr to static_cast<unsigned int>","pattern":"\\(unsigned\\s+int\\)\\s*([a-zA-Z_]\\w*(?:\\([^)]*\\))?)","replacement":"static_cast<unsigned int>($1)","mode":"regex","priority":75,"requires_context":false}
{"id":"cast_uint64","category":"cast","description":"(uint64_t)expr to static_cast<uint64_t>","pattern":"\\(uint64_t\\)\\s*([a-zA-Z_]\\w*(?:\\([^)]*\\))?)","replacement":"static_cast<uint64_t>($1)","mode":"regex","priority":75,"requires_context":false}
