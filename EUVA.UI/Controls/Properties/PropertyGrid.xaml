<UserControl x:Class="EUVA.UI.Controls.Properties.PropertyGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource Background}"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                Padding="10,5">
            <TextBlock Text="Properties"
                       Foreground="{DynamicResource ForegroundSecondary}"
                       FontFamily="Segoe UI" FontSize="11"
                       FontWeight="SemiBold"/>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <ItemsControl x:Name="PropertiesControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource SeparatorLine}"
                                BorderThickness="0,0,0,1"
                                Padding="10,5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ItemSelectedBackground}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Key}"
                                           Foreground="{DynamicResource PropertyKey}"
                                           FontFamily="Segoe UI" FontSize="11"
                                           VerticalAlignment="Top"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Value}"
                                           Foreground="{DynamicResource PropertyValue}"
                                           FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"
                                           Margin="6,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
