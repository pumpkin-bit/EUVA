<Window x:Class="EUVA.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EUVA.UI.Controls"
        xmlns:hex="clr-namespace:EUVA.UI.Controls.Hex"
        xmlns:decomp="clr-namespace:EUVA.UI.Controls.Decompilation"
        xmlns:props="clr-namespace:EUVA.UI.Controls.Properties"
        xmlns:trees="clr-namespace:EUVA.UI.Controls.Trees"
        Title="EUVA"
        Height="920" Width="1640"
        MinHeight="600" MinWidth="1000"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#45475A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#181825"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush"      Value="#89B4FA"/>
            <Setter Property="SelectionBrush"  Value="#89B4FA"/>
            <Setter Property="Padding"         Value="5,3"/>
            <Setter Property="FontFamily"      Value="JetBrains Mono, Cascadia Mono, Consolas"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="#6C7086"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="12,6">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter TargetName="bd" Property="Background"  Value="#24273A"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#A6ADC8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#181825"/>
            <Setter Property="Foreground"      Value="#6C7086"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush"     Value="#313244"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"   Value="#CDD6F4"/>
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Padding"      Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#363A4F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

      
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#11111B"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="templateRoot"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <Grid Margin="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="IconColumn" MinWidth="22" SharedSizeGroup="MenuItemIconColumnGroup" Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="IGTColumn" SharedSizeGroup="MenuItemIGTColumnGroup" Width="Auto"/>
                                    <ColumnDefinition x:Name="ArrowColumn" Width="14"/>
                                </Grid.ColumnDefinitions>
                                
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" HorizontalAlignment="Center" VerticalAlignment="Center" Width="16" Height="16" Margin="3"/>
                                <ContentPresenter Grid.Column="1" x:Name="HeaderHost" ContentSource="Header" Margin="4,2,4,2" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="InputGestureText" Text="{TemplateBinding InputGestureText}" Margin="15,2,5,2" VerticalAlignment="Center" Foreground="#A6ADC8"/>
                                <Path Grid.Column="3" x:Name="RightArrow" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#CDD6F4" Data="M 0,0 L 4,4 L 0,8 Z"/>

                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="Fade" Placement="Right">
                                    <Border x:Name="SubMenuBorder" Background="#181825" BorderBrush="#45475A" BorderThickness="1" SnapsToDevicePixels="True" Margin="0,0,5,5">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="5" Opacity="0.4" ShadowDepth="2" Direction="315" Color="Black"/>
                                        </Border.Effect>
                                        <ScrollViewer Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom"/>
                                <Setter TargetName="templateRoot" Property="Padding" Value="6,2"/>
                                <Setter TargetName="HeaderHost" Property="Margin" Value="0"/>
                                <Setter TargetName="InputGestureText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IconColumn" Property="MinWidth" Value="0"/>
                                <Setter TargetName="IconColumn" Property="Width" Value="0"/>
                                <Setter TargetName="IGTColumn" Property="Width" Value="0"/>
                                <Setter TargetName="ArrowColumn" Property="Width" Value="0"/>
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="templateRoot" Property="Padding" Value="6,2"/>
                                <Setter TargetName="HeaderHost" Property="Margin" Value="0"/>
                                <Setter TargetName="IconColumn" Property="MinWidth" Value="0"/>
                                <Setter TargetName="IconColumn" Property="Width" Value="0"/>
                                <Setter TargetName="IGTColumn" Property="Width" Value="0"/>
                                <Setter TargetName="ArrowColumn" Property="Width" Value="0"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="templateRoot" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                                <Setter TargetName="InputGestureText" Property="Foreground" Value="#89B4FA"/>
                                <Setter TargetName="RightArrow" Property="Fill" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#585B70"/>
                                <Setter TargetName="InputGestureText" Property="Foreground" Value="#585B70"/>
                                <Setter TargetName="RightArrow" Property="Fill" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="4,2"/>
        </Style>

        
        <Style x:Key="DarkComboToggle" TargetType="ToggleButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClickMode" Value="Press"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="#2A2A3E"
                                BorderBrush="#45475A"
                                BorderThickness="1"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="Transparent"/>
                                <Path Grid.Column="1"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="#6C7086"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#89B4FA"/>
                                <Setter TargetName="bd" Property="Background" Value="#313244"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#363A4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#2A2A3E"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource DarkComboToggle}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1E1E2E"
                                            BorderBrush="#45475A"
                                            BorderThickness="1"
                                            CornerRadius="0,0,4,4"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  
            <RowDefinition Height="Auto"/>   
            <RowDefinition Height="*"/>     
            <RowDefinition Height="155"/>    
            <RowDefinition Height="22"/>     
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#181825"
                BorderBrush="#313244" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="32" Background="#89B4FA"
                        VerticalAlignment="Stretch">
                    <TextBlock Text="⬡" Foreground="#1E1E2E"
                               FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <Menu Grid.Column="1"
                      Background="Transparent"
                      Foreground="#CDD6F4"
                      VerticalAlignment="Center"
                      Margin="4,0">

                    <MenuItem Header="_File" Padding="8,4">
                        <MenuItem Header="Open…"        Click="MenuOpen_Click"
                                  InputGestureText="Ctrl+O"/>
                        <Separator/>
                        <MenuItem Header="Exit"         Click="MenuExit_Click"/>
                    </MenuItem>

                    <MenuItem Header="_Analysis" Padding="8,4">
                        <MenuItem Header="Run Detectors"     Click="MenuRunDetectors_Click"/>
                        <MenuItem Header="Calculate Entropy" Click="MenuCalculateEntropy_Click"/>
                    </MenuItem>

                    <MenuItem Header="_Settings" Padding="8,4">
                        <MenuItem Header="Hotkeys">
                            <MenuItem Header="Select .htk file…" Click="MenuHotkeys_Click"/>
                        </MenuItem>
                        <MenuItem Header="Themes">
                            <MenuItem Header="Select Theme…" Click="MenuThemeSelect_Click"/>
                        </MenuItem>
                        <MenuItem Header="Watch Script" Click="MenuWatchScript_Click"/>
                    </MenuItem>

                    <MenuItem x:Name="BtnEndian" Header="Endian: LE"
                              Padding="8,4" Click="BtnEndian_Click"/>

                    <MenuItem Header="_Encoding" Padding="8,4">
                        <MenuItem Header="Latin-1"             Click="ChangeEncoding_Click" Tag="28591"/>
                        <MenuItem Header="ANSI (Win-1251)"     Click="ChangeEncoding_Click" Tag="1251"/>
                        <MenuItem Header="DOS (CP-866)"        Click="ChangeEncoding_Click" Tag="866"/>
                        <MenuItem Header="Macintosh (Cyrillic)" Click="ChangeEncoding_Click" Tag="10007"/>
                        <MenuItem Header="UTF-8"               Click="ChangeEncoding_Click" Tag="65001"/>
                    </MenuItem>

                    <MenuItem Header="_YARA" Padding="8,4">
                        <MenuItem Header="Load YARAx Rules"  Click="BtnLoadYaraRules_Click"/>
                        <MenuItem Header="Run YARAx Scan"    Click="BtnRunYaraScan_Click"/>
                        <MenuItem Header="Cancel YARAx"      Click="BtnCancelYaraScan_Click"/>
                    </MenuItem>

                    <MenuItem Header="_View" Padding="8,4">
                        <MenuItem x:Name="MagicModeMenuItem"
                                  Header="Activate MediaHex"
                                  IsCheckable="True"
                                  Click="OnMediaHexClick"
                                  InputGestureText="Ctrl+M"/>
                        <Separator/>
                        <MenuItem Header="Disassembler"
                                  Click="MenuDisassembler_Click"
                                  InputGestureText="Ctrl+D"/>
                        <MenuItem Header="Decompiler"
                                  Click="MenuDecompiler_Click"
                                  InputGestureText="Ctrl+Shift+D"/>
                    </MenuItem>
                </Menu>

                <Border Grid.Column="2" Padding="10,0">
                    <TextBlock x:Name="StatusText"
                               Text="No file loaded"
                               Foreground="#A6E3A1"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid x:Name="MainEditorGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="140"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="310" MinWidth="160"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#181825"
                    BorderBrush="#313244" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                   
                    <Border Grid.Row="0"
                            Background="#1E1E2E"
                            BorderBrush="#313244" BorderThickness="0,0,0,1"
                            Padding="10,5">
                        <TextBlock Text="Data Patterns"
                                   Foreground="#A6ADC8"
                                   FontFamily="Segoe UI" FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <trees:StructureTreeView Grid.Row="1"
                        x:Name="StructureTree"
                        StructureSelected="StructureTree_StructureSelected"/>
                </Grid>
            </Border>

      
            <GridSplitter Grid.Column="1" Width="1"
                          HorizontalAlignment="Stretch"
                          Background="#45475A" Cursor="SizeWE"/>

        
            <Border Grid.Column="2" Background="#1E1E2E">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <hex:VirtualizedHexView x:Name="HexView"
                        Grid.Column="0"
                        OffsetSelected="HexView_OffsetSelected"/>
                    <Rectangle Grid.Column="1" Fill="#313244" Width="1"/>
                    <decomp:ByteMinimapControl x:Name="ByteMinimap"
                        Grid.Column="2"
                        NavigateRequested="ByteMinimap_NavigateRequested"/>
                </Grid>
            </Border>

            
            <GridSplitter Grid.Column="3" Width="1"
                          HorizontalAlignment="Stretch"
                          Background="#45475A" Cursor="SizeWE"/>

         
            <Border Grid.Column="4"
                    Background="#181825"
                    BorderBrush="#313244" BorderThickness="1,0,0,0">
                <TabControl x:Name="RightTabControl"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">

                
                    <TabItem Header="Inspector">
                        <ListView x:Name="DataInspectorList"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#CDD6F4"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding"  Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#313244"
                                            BorderThickness="0,0,0,1"
                                            Padding="10,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#B4BEFE"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Foreground="#FAB387"
                                                       FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </TabItem>

                  
                    <TabItem Header="Search">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#1E1E2E"
                                    BorderBrush="#313244" BorderThickness="0,0,0,1"
                                    Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="Search address / value"
                                               Foreground="#6C7086"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Margin="0,0,0,5"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SearchInput"/>
                                        <Button Grid.Column="1"
                                                Content="Go" Width="40" Height="24"
                                                Margin="5,0,0,0"
                                                Click="BtnSearch_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <DataGrid Grid.Row="1"
                                      x:Name="SearchResultsGrid"
                                      Background="Transparent"
                                      Foreground="#CDD6F4"
                                      BorderThickness="0"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#0D181825"
                                      GridLinesVisibility="None"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                                      FontSize="11">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Offset" Binding="{Binding Offset}" Width="85"/>
                                    <DataGridTextColumn Header="Size"   Binding="{Binding Size}"   Width="46"/>
                                    <DataGridTextColumn Header="Value"  Binding="{Binding Value}"  Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                 
                    <TabItem Header="Detections">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#1E1E2E"
                                    BorderBrush="#313244" BorderThickness="0,0,0,1"
                                    Padding="10,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TxtDetectionStatus"
                                               Text="Run Detectors or load YARA rules to begin"
                                               Foreground="#6C7086"
                                               FontFamily="Segoe UI" FontSize="10"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TxtYaraMatchCount"
                                               Grid.Column="1" Text=""
                                               Foreground="#A6E3A1"
                                               FontFamily="Segoe UI" FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>

                            <ListView x:Name="DetectionList"
                                      Grid.Row="1"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="#CDD6F4"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      MouseDoubleClick="DetectionList_MouseDoubleClick"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#313244"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#363A4F"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#313244"
                                                BorderThickness="0,0,0,1"
                                                Padding="10,6">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="#89B4FA"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,7,0"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#CDD6F4"
                                                               FontFamily="Segoe UI"
                                                               FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Type}"
                                                           Foreground="#6C7086"
                                                           FontFamily="Segoe UI" FontSize="10"
                                                           Margin="13,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Properties">
                        <props:PropertyGrid x:Name="PropertyGrid"/>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="#181825"
                BorderBrush="#313244" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="#1E1E2E"
                        BorderBrush="#313244" BorderThickness="0,0,0,1"
                        Padding="10,3">
                    <TextBlock Text="Console Output"
                               Foreground="#6C7086"
                               FontFamily="Segoe UI" FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>
                <RichTextBox Grid.Row="1"
                         x:Name="ConsoleLog"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#CDD6F4"
                         BorderThickness="0"
                         FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                         FontSize="11"
                         Padding="10,5"
                         VerticalScrollBarVisibility="Auto"
                         IsDocumentEnabled="False">
                    <FlowDocument>
                        <Paragraph x:Name="ConsoleLogParagraph"/>
                    </FlowDocument>
                </RichTextBox>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="#181825"
                BorderBrush="#313244" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   
                    <ColumnDefinition Width="Auto"/>   
                    <ColumnDefinition Width="Auto"/>   
                    <ColumnDefinition Width="Auto"/> 
                    <ColumnDefinition Width="Auto"/>   
                    <ColumnDefinition Width="Auto"/>   
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>  
                    <ColumnDefinition Width="Auto"/>   
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#89B4FA" Padding="10,0">
                    <TextBlock Text="EUVA"
                               Foreground="#1E1E2E"
                               FontFamily="Segoe UI" FontSize="10"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="5"
                           x:Name="SbSelectionSize"
                           Text=""
                           Foreground="#6C7086"
                           FontFamily="Segoe UI" FontSize="10"
                           VerticalAlignment="Center"/>
                           
                <TextBlock Grid.Column="7"
                           x:Name="SbEncoding"
                           Text="Latin-1"
                           Foreground="#6C7086"
                           FontFamily="Segoe UI" FontSize="10"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>

                <TextBlock Grid.Column="8"
                           x:Name="SbFileSize"
                           Text=""
                           Foreground="#89B4FA"
                           FontFamily="JetBrains Mono, Cascadia Mono, Consolas"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
            </Grid>
        </Border>

    </Grid>
</Window>
