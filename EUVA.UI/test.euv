dos_msg = find("54 68 69 73 20 70 72 6F 67 72 61 6D")

if dos_msg:
    log("dos stub found starting transformation...")
    fill(dos_msg, 38, 0x20)
    write_string(dos_msg, "script loaded")
    nop(offset(dos_msg, 30), 4)
    
    log("Patch successfully applied dos header modified!")
else:
    log("Signature mismatch dos message not found.")
